PORT=5000
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_KEY=your_supabase_service_role_key
JWT_SECRET=your_jwt_secret_here_change_this
JWT_EXPIRES_IN=7d
YOUTUBE_API_KEY=your_youtube_api_key
SMTP_HOST=smtp.mailprovider.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password
SMTP_FROM=Islam Learning Platform <no-reply@yourdomain.com>
BACKEND_PUBLIC_URL=https://api.yourdomain.com
RESET_PASSWORD_URL=islam-learning-platform://reset-password

# Optional: if set, POST /api/sync/* requires header:
#   X-ILP-Sync-Secret: <same value>
# (recommended for production). If unset, sync uses JWT like other routes.
ILP_SYNC_SECRET=
